# Used by docker-compose.yml (copy to .env in the repo root).

# Tailscale auth key for the container sidecar.
# Create at https://login.tailscale.com/admin/settings/keys
TS_AUTHKEY=

# FRED API key for the risk-free rate (free at https://fredaccount.stlouisfed.org).
FRED_API_KEY=

# Background mispricing scanner (off by default; set to 1 to enable).
OFV_SCANNER_ENABLED=0
