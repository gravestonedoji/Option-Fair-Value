# FRED API key for the risk-free rate (3-month Treasury, DGS3MO).
# Get a free key at https://fredaccount.stlouisfed.org
# Copy this file to backend/.env and fill in, OR set the env var directly:
#   $env:FRED_API_KEY = "..."
FRED_API_KEY=

# --- Deployment knobs (all optional; defaults suit local dev) ---------------

# Comma-separated CORS origins. Only needed for split deploys (frontend hosted
# separately); when the backend serves the built frontend, CORS never applies.
#OFV_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Directory with the built frontend (frontend/dist). If it exists, the backend
# serves it at "/". Defaults to <repo>/frontend/dist.
#OFV_STATIC_DIR=

# SQLite cache file path. Defaults to ~/.option_fair_value/cache.sqlite
#OFV_CACHE_PATH=

# Cache TTLs in seconds. Raise OFV_TTL_QUOTES (e.g. 300) on public deploys so
# each unique chain hits Yahoo at most once per window regardless of traffic.
#OFV_TTL_QUOTES=60
#OFV_TTL_EXPIRIES=86400
#OFV_TTL_RATE=3600

# Per-IP rate limits (slowapi syntax).
#OFV_RATE_LIMIT_FAIRVALUE=10/minute
#OFV_RATE_LIMIT_DATA=30/minute

# Max concurrent Monte Carlo computations (each ~1-2s of CPU).
#OFV_MAX_CONCURRENT_PRICING=2

# Risk-free rate used by /analysis and the scanner when FRED is unavailable.
#OFV_FALLBACK_RATE=0.04

# --- Mispricing scanner (background watchlist sweep + alerts) ---------------

# Master switch; the scanner is OFF unless this is exactly "1".
#OFV_SCANNER_ENABLED=1

# Symbols to sweep, comma-separated.
#OFV_SCANNER_WATCHLIST=SPY,QQQ,AAPL,NVDA

# Seconds between sweeps during market hours (data is ~15-min delayed, so
# values under ~300 add load without adding information).
#OFV_SCANNER_INTERVAL=600

# A contract must stay flagged for this many consecutive sweeps before it
# becomes an active alert (filters one-tick quote glitches).
#OFV_SCANNER_PERSISTENCE=2

# Expiry window and per-symbol cap for each sweep.
#OFV_SCANNER_MIN_DTE=3
#OFV_SCANNER_MAX_DTE=75
#OFV_SCANNER_MAX_EXPIRIES=4
